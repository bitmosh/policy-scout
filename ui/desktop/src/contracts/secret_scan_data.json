{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Output of: policy-scout scan dir/staged/history --json",
  "type": "object",
  "required": ["scan_id", "scan_type", "target", "finding_count", "severity_counts", "files_scanned", "commits_scanned", "duration_ms", "errors", "findings"],
  "properties": {
    "scan_id": { "type": "string" },
    "scan_type": { "type": "string" },
    "target": { "type": "string" },
    "finding_count": { "type": "integer" },
    "severity_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "files_scanned": { "type": "integer" },
    "commits_scanned": { "type": "integer" },
    "duration_ms": { "type": "number" },
    "errors": { "type": "array", "items": { "type": "string" } },
    "findings": { "type": "array" }
  },
  "additionalProperties": true
}
